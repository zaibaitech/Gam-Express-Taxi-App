# ─────────────────────────────────────────────────────────────
#  Gam Express Taxi PWA — Environment Variables
#  Copy this to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────

# Supabase — found in Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Service Role Key — NEVER expose this to the browser
# Found in Project Settings → API → service_role (secret)
# Used only in /app/api/admin/* server routes
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin panel password — you choose this, keep it secret
NEXT_PUBLIC_ADMIN_PASSWORD=your-secret-admin-password
